# IDE
.idea

# Python cache
__pycache__/
*.pyc
*.pyo

# Runtime outputs
/saves
/logs
/tables

# evaluations: ignore bulk outputs (generations, logs) but keep the small
# result artifacts, which runpod/publish_results.sh commits to main.
/evaluations/*
!/evaluations/nllOutputs/
!/evaluations/worstCase/
!/evaluations/evalJudge/
!/evaluations/mmluOutputs/
!/evaluations/results_db.json

# Debug config dumps written to the repo root during training (src/train.py)
/tmp-config-data.yaml
/trainerargs.yaml
/trainerargs-cfg.yaml

# PUBLIC-REPO SAFETY: this fork is public. Never commit local env, session
# state, or kernel-activity notebooks (they can echo environment/tokens).
/.venv/
/.env
.env.*
/.claude/
/remote-kernels/
*.ipynb